/*
 * lib/nats/nats_dl_table.def — single source of truth for the libnats
 * function-pointer table.  Used by nats_dl.h (struct field declarations)
 * and nats_dl.c (dlsym population).
 *
 * Each entry expands via the NATS_DL_FN(name) macro the includer
 * defines.  See nats_dl.h for the declaration use, nats_dl.c for
 * the dlsym use.
 */

