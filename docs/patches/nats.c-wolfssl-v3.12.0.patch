-endif(NATS_BUILD_WITH_TLS)
+endif(NATS_BUILD_WITH_TLS AND NOT NATS_BUILD_WITH_WOLFSSL)
+
+if(NATS_BUILD_WITH_WOLFSSL)
+  if(DEFINED ENV{NATS_WOLFSSL_DIR})
+    set(NATS_WOLFSSL_DIR "$ENV{NATS_WOLFSSL_DIR}")
