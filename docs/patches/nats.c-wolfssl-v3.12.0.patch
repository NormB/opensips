@@ -735,9 +739,16 @@ _makeTLSConn(natsConnection *nc)
 #endif
             if (nc->tlsName != NULL)
             {
+                // SSL_set_hostflags / SSL_set1_host aren't in
+                // wolfSSL's OpenSSL compat layer.  Under wolfSSL
+                // we rely on SSL_set_tlsext_host_name (called
+                // below) plus the verify callback for cert
+                // hostname checking.
+#if !defined(NATS_HAS_WOLFSSL)
                 SSL_set_hostflags(ssl, X509_CHECK_FLAG_NO_PARTIAL_WILDCARDS);
                 if (!SSL_set1_host(ssl, nc->tlsName))
                     s = nats_setError(NATS_SSL_ERROR, "unable to set expected hostname '%s'", nc->tlsName);
+#endif
             }
             if (s == NATS_OK)
             {
diff --git a/src/natsp.h b/src/natsp.h
index edd5da2..6ab69eb 100644
--- a/src/natsp.h
+++ b/src/natsp.h
@@ -20,6 +20,16 @@
 # include "include/n-unix.h"
 #endif
 
+#if defined(NATS_HAS_WOLFSSL)
+// Must come before <openssl/*> so wolfSSL's compatibility-layer
+// macros (SSL_get_error -> wolfSSL_get_error, EVP_sha256 ->
+// wolfSSL_EVP_sha256, etc.) are in effect when the subsequent
+// <openssl/*.h> are processed.  The matching include_directories()
+// `BEFORE` in src/CMakeLists.txt makes <openssl/ssl.h> resolve to
+// wolfSSL's own openssl-compat header rather than the system one.
+#include <wolfssl/options.h>
+#endif
+
 #if defined(NATS_HAS_TLS)
 #include <openssl/ssl.h>
 #include <openssl/err.h>
