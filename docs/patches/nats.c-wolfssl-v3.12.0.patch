diff --git a/src/conn.c b/src/conn.c
index d7ba4501..627c05c5 100644
--- a/src/conn.c
+++ b/src/conn.c
@@ -44,6 +44,10 @@
 #define NATS_EVENT_ACTION_ADD       (true)
 #define NATS_EVENT_ACTION_REMOVE    (false)
 
+#ifdef NATS_HAS_WOLFSSL
+typedef int (*SSL_verify_cb)(int preverify_ok, X509_STORE_CTX *x509_ctx);
+#endif
+
 #ifdef DEV_MODE
 // For type safety
 
@@ -735,9 +739,17 @@ _makeTLSConn(natsConnection *nc)
 #endif
             if (nc->tlsName != NULL)
             {
+                // The SSL_set_hostflags / SSL_set1_host pair is not part of
+                // wolfSSL's OpenSSL compatibility layer.  Under wolfSSL we
+                // fall back to the SNI-only path (SSL_set_tlsext_host_name
+                // below already handles hostname presentation); the cert
+                // hostname-verify is then enforced via the verify callback
+                // and X509_check_host from the compat layer.
+#if !defined(NATS_HAS_WOLFSSL)
                 SSL_set_hostflags(ssl, X509_CHECK_FLAG_NO_PARTIAL_WILDCARDS);
                 if (!SSL_set1_host(ssl, nc->tlsName))
                     s = nats_setError(NATS_SSL_ERROR, "unable to set expected hostname '%s'", nc->tlsName);
+#endif
             }
             if (s == NATS_OK)
             {
