####### nats_consumer bench cfg ###################################
#
# Minimal opensips.cfg for the bench harness.  Drains a JetStream
# pull consumer in a tight timer-route loop and exposes counters
# via the MI socket so the harness can poll how many messages have
# been acked.
#
# Placeholders rendered by the harness:
#   @@MODULES@@      -- absolute path to the modules dir
#   @@NATS_URL@@     -- nats://host:port[,...]
#   @@MI_PORT@@      -- UDP port for mi_datagram
#   @@STREAM@@       -- JetStream stream name
#   @@SUBJECT@@      -- subject filter (e.g. bench.>)
#   @@HANDLE_ID@@    -- consumer handle id used by the script

log_level=4
xlog_level=3
debug_mode=no
stderror_enabled=yes
udp_workers=4
tcp_workers=0

socket=udp:127.0.0.1:5060
mpath="@@MODULES@@/"

# proto_udp is shipped as a separate module in OpenSIPS 4.x and
# must be loaded for socket=udp:... to come up; otherwise the
# core fails with "no transport protocol loaded".  proto_udp.so
# resolves under @@MODULES@@/ in the standard install path.
loadmodule "proto_udp.so"

# MI over UDP datagram so the harness can read per-handle counters
# (msgs, acks, last_seq, etc.).
loadmodule "mi_datagram.so"
modparam("mi_datagram", "socket_name", "udp:127.0.0.1:@@MI_PORT@@")

# event_nats owns the lib/nats pool registration; without it
# nats_consumer cannot get a connection at child_init.  Loaded first.
loadmodule "event_nats.so"
modparam("event_nats", "nats_url", "@@NATS_URL@@")

loadmodule "nats_consumer.so"
# persist_handles=0: we re-bind every run; no on-disk state.
# Module-global Fetch tuning -- the harness templates these so we can
# sweep without recompiling.  Defaults match the module defaults
# (10 / 1000) so a no-knob run reproduces the baseline numbers.
modparam("nats_consumer", "fetch_batch",      @@FETCH_BATCH@@)
modparam("nats_consumer", "fetch_timeout_ms", @@FETCH_TIMEOUT_MS@@)

####### routes #####################################################

startup_route {
    xlog("L_INFO", "nats_consumer bench: startup; binding handle\n");
    # Single bind via the cmd_export.  Durable name == handle id so
    # the consumer survives restarts (irrelevant for the bench since
    # we tear down after each run, but matches typical operator
    # config).  Auto-ack=manual so the script controls when each
    # message is acknowledged.
    # nats_consumer_bind uses k=v;k=v parsing.  filter= is the
    # JetStream consumer's subject filter; matches the subject(s)
    # we publish to in the bench harness.  durable= name lets the
    # consumer survive opensips restarts (irrelevant for the bench
    # but matches typical operator config).  ack_wait is generous
    # so we never re-deliver during the drain.
    # ring_capacity must be >= 2*fetch_batch so a freshly-arrived
    # Fetch batch can land in the SHM ring without backpressure-
    # dropping, which would force broker redeliveries after ack_wait.
    nats_consumer_bind("id=@@HANDLE_ID@@;stream=@@STREAM@@;filter=@@SUBJECT@@;durable=@@HANDLE_ID@@;ack_wait=30s;max_ack_pending=4096;ring_capacity=@@RING_CAPACITY@@");
}

# Tight drain loop.  Fires every 50 ms; on each tick pulls up to 256
# messages with a 100 ms inner timeout, acks each.  At steady state
#
# Two drain modes are templated:
#
# - DRAIN_MODE=single (default; legacy) -- one nats_fetch + one
#   nats_ack per message.  The per-message OpenSIPS script
#   interpreter overhead (function call, var arith, while-loop
#   bookkeeping) sets a hard cap around 2 000 msgs/sec on this
#   hardware regardless of fetch_batch / fetch_timeout_ms.
#
# - DRAIN_MODE=batch -- nats_fetch_batch + nats_batch_select +
#   nats_ack inside a tight loop.  The fetch + script-pop cost is
#   amortized across the whole batch, lifting throughput by ~Nx.
# this drains the stream as fast as the consumer process can deliver
# into the SHM ring -- the ack rate is the throughput metric the
# bench measures.
timer_route[drain, @@TIMER_INTERVAL@@] {
    @@DRAIN_BODY@@
}

route {
    exit;
}
