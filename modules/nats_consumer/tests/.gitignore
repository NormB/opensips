*.o
*.d

# Compiled test binaries: every test_*.c builds an extensionless test_* binary.
# Ignore those, but keep the sources, shell runners and python helpers tracked.
# (Pattern replaces the previously hand-maintained per-binary list, which drifted
# out of date as tests were added/deleted.)
test_*
!test_*.c
!test_*.sh
!test_*.py
