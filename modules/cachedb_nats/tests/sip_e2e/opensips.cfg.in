####### usrloc <-> NATS cachedb e2e test cfg #####################
#
# Drives the integration test suite for cachedb_nats acting as the
# storage backend for usrloc in cluster_mode=full-sharing-cachedb.
#
# Boots once per `run.sh` invocation; tested by many cases under cases/.
# Two-instance cases re-render this template with @@INSTANCE@@-specific
# ports and re-boot the binary as instance B.
#
# usrloc full-sharing-cachedb mode requires clusterer to be loaded for
# shtag / pinging coordination even when actual contact data lives in
# cachedb; we provide a single-node clusterer config in DB-less mode.
#
# Substitutions performed by run.sh:
#   @@MODULES@@      ->  flat-symlinked module .so directory
#   @@NATS_URL@@     ->  NATS broker URL (plain nats:// for cachedb_nats)
#   @@CACHEDB_URL@@  ->  cachedb URL (nats:loc://host:port/)
#   @@SIP_PORT@@     ->  UDP listen port
#   @@MI_PORT@@      ->  MI datagram UDP port
#   @@CLUSTER_PORT@@ ->  clusterer bin: UDP port
#   @@NODE_ID@@      ->  numeric clusterer my_node_id (1, 2, ...)
#   @@KV_BUCKET@@    ->  JetStream-KV bucket name
#   @@INSTANCE@@     ->  short id ("A", "B", ...) for log tagging

log_level=3
xlog_level=3
stderror_enabled=yes
syslog_enabled=no

udp_workers=2
tcp_workers=0

socket=udp:127.0.0.1:@@SIP_PORT@@
socket=bin:127.0.0.1:@@CLUSTER_PORT@@

mpath="@@MODULES@@/"

####### loaded modules ###########################################

loadmodule "proto_udp.so"
loadmodule "sl.so"
loadmodule "tm.so"
loadmodule "rr.so"
loadmodule "maxfwd.so"
loadmodule "signaling.so"
loadmodule "sipmsgops.so"

loadmodule "mi_datagram.so"
modparam("mi_datagram", "socket_name", "udp:127.0.0.1:@@MI_PORT@@")

loadmodule "proto_bin.so"

loadmodule "clusterer.so"
modparam("clusterer", "db_mode",      0)
modparam("clusterer", "my_node_id",   @@NODE_ID@@)
modparam("clusterer", "my_node_info",
    "cluster_id=1, url=bin:127.0.0.1:@@CLUSTER_PORT@@, "
    "priority=50, no_ping=1")

loadmodule "cachedb_nats.so"
modparam("cachedb_nats", "cachedb_url",     "@@CACHEDB_URL@@")
modparam("cachedb_nats", "kv_bucket",       "@@KV_BUCKET@@")
modparam("cachedb_nats", "kv_replicas",     1)
modparam("cachedb_nats", "kv_history",      1)
# [HREV-3/D6] physical retention past logical expiry; 0 = reclaim ASAP.
modparam("cachedb_nats", "nats_expired_linger", @@EXPIRED_LINGER@@)
# reaper cadence; TTL cases shrink it so reaper-only reclamation is testable.
modparam("cachedb_nats", "nats_reap_interval",  @@REAP_INTERVAL@@)
# acknowledgment flag for reaper-off runs (case 088 failure-mode probe).
modparam("cachedb_nats", "nats_unsafe_ttl_only", @@UNSAFE_TTL_ONLY@@)
modparam("cachedb_nats", "fts_json_prefix", "json_")
modparam("cachedb_nats", "enable_search_index",   @@ENABLE_INDEX@@)
modparam("cachedb_nats", "index_buckets",         @@INDEX_BUCKETS@@)
modparam("cachedb_nats", "dedicated_watcher_proc", @@DEDICATED_WATCHER@@)
# Watch every KV mutation; the watcher updates the SHM-backed
# JSON-FTS index live so cross-instance changes propagate without
# the per-query lazy self-heal.  Required for the dedicated-watcher feature (the
# dedicated proc is gated on kv_watch_count > 0).
modparam("cachedb_nats", "kv_watch", "json_>")

loadmodule "usrloc.so"
modparam("usrloc", "cluster_mode",     "full-sharing-cachedb")
modparam("usrloc", "location_cluster", 1)
modparam("usrloc", "cachedb_url",      "@@CACHEDB_URL@@")
modparam("usrloc", "nat_bflag",        "NAT")
# use_domain=1 keeps user@host as the AoR.  The upstream default
# flipped from 1 to 0 at some point; the e2e suite asserts on
# "alice@127.0.0.1"-shaped AoR keys so we pin the legacy behaviour
# explicitly here.  registrar imports this from usrloc at init
# (see lib/reg/common.c:reg_init_globals), so setting it on
# usrloc alone is sufficient.
modparam("usrloc", "use_domain",       1)

loadmodule "registrar.so"
# TTL e2e cases register with Expires: 3; without this the default
# min_expires=60 silently raises them and every expiry wait times out.
modparam("registrar", "min_expires", 0)
modparam("registrar", "tcp_persistent_flag", "TCP_PERSISTENT")

####### routes ###################################################

startup_route {
    xlog("L_INFO", "[@@INSTANCE@@] cachedb_nats e2e cfg up\n");
}

route {
    if (!mf_process_maxfwd_header(10)) {
        sl_send_reply(483, "Too Many Hops");
        exit;
    }

    if (is_method("REGISTER")) {
        xlog("L_INFO", "[@@INSTANCE@@] REGISTER from $fU contact=$ct expires=$hdr(Expires)\n");
        if (!save("location")) {
            xlog("L_ERR", "[@@INSTANCE@@] save() failed for $fU\n");
            sl_send_reply(500, "Internal Server Error");
            exit;
        }
        exit;
    }

    if (is_method("OPTIONS")) {
        sl_send_reply(200, "OK");
        exit;
    }

    # visibility probe for the TTL e2e cases: MESSAGE looks the AoR up.
    # 202 = a live binding exists; 404 = none (expired contacts are never
    # served, whatever nats_expired_linger keeps physically stored).
    if (is_method("MESSAGE")) {
        if (!lookup("location")) {
            sl_send_reply(404, "Not Found");
            exit;
        }
        sl_send_reply(202, "Binding Exists");
        exit;
    }

    if (is_method("ACK")) {
        exit;
    }

    sl_send_reply(405, "Method Not Allowed");
    exit;
}
